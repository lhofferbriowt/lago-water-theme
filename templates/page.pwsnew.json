\/ 20%); will-change: background-size;}"],"name":"t:sections.custom-liquid.presets.name","settings":{"custom_liquid":"<section class=\"cst_text_animation\" id=\"text-sec\">\n  <div class=\"containers\">\n    <div class=\"tt-text-reveal\">\n      <p>Have you ever felt you have no other option?<\/p>\n      <p>Lago was founded with a vision to empower entrepreneurs entering the water industry by providing the essential tools and solutions they need to achieve true financial freedom.<\/p>\n      <p>Our mission is to help every consumer hydrate happier, healthier and contribute to building a better planet.<\/p>\n      <p>Together we're building a community of changemakers - people who believe in creating a brighter, cleaner future. With every sip, you are supporting a more sustainable world.<\/p>\n   <p class=\"lag-anim\">Lago is the leader in innovative pure water solutions.<\/p>\n    <\/div>\n  <\/div>\n<\/section>\n\n<div id=\"wc-start-sentinel\" class=\"wc-start-sentinel\" aria-hidden=\"true\"><\/div>","color_scheme":"","padding_top":20,"padding_bottom":40}},"custom_liquid_rU7YcK":{"type":"custom-liquid","disabled":true,"name":"t:sections.custom-liquid.presets.name","settings":{"custom_liquid":"<div style=\"text-align:center;\">\n<img src=\"https:\/\/cdn.shopify.com\/s\/files\/1\/0940\/1168\/7234\/files\/About_Us_Product_7.png\" style=\"width: 70%;margin: 0 auto;\" alt=\"\">\n<\/div>","color_scheme":"","padding_top":60,"padding_bottom":40}},"custom_liquid_aBCrrk":{"type":"custom-liquid","disabled":true,"name":"t:sections.custom-liquid.presets.name","settings":{"custom_liquid":"<section class=\"section lago-text\">\n\n    <div class=\"section-content\">\n  \n      <h2 class=\"lag-anim\">Lago is the leader in innovative pure water solutions<\/h2>\n<p class=\"lag-content\">Scroll down to discover how this innovative water cooler delivers exceptional convenience and purity.<\/p>\n  \n    <\/div>\n <!--<img class=\"intross-cooler\" src=\"https:\/\/cdn.shopify.com\/s\/files\/1\/0940\/1168\/7234\/files\/filter.webp\" alt=\"Lago cooler\">-->\n  <\/section>\n\n<div class=\"main-anim\"> \n\n<section class=\"section anim-trigger-spacer\" aria-hidden=\"true\"><\/section>\n\n  <section class=\"section bg1\" data-index=\"0\"><\/section>\n\n  <div id=\"overlay\">\n    \n    <div id=\"pinned-container\">\n      \n      <!-- Central image illustrating the water cooler. -->\n      <div class=\"central-image\">\n        <img src=\"https:\/\/cdn.shopify.com\/s\/files\/1\/0940\/1168\/7234\/files\/filter.webp\" alt=\"Exploded view of water cooler\">\n        <!-- Pin markers overlayed on the image. -->\n        <div class=\"pin pin1\"><\/div>\n        <div class=\"pin pin2\"><\/div>\n        <div class=\"pin pin3\"><\/div>\n        <div class=\"pin pin4\"><\/div>\n        <div class=\"pin pin5\"><\/div>\n      <\/div>\n      \n      <!-- Cards describing each feature. These slide in from left or right on scroll. -->\n      \n      <div class=\"card right card1\">\n      \n        <div class=\"card-inner\">\n      \n          <div class=\"card-top\">\n            <img src=\"https:\/\/cdn.shopify.com\/s\/files\/1\/0940\/1168\/7234\/files\/icon-1.svg\" alt=\"\">\n            <h3>UV Self Cleaning<\/h3>\n          <\/div>\n        \n          <div class=\"card-desc\">\n            <img src=\"https:\/\/cdn.shopify.com\/s\/files\/1\/0940\/1168\/7234\/files\/Group_63.webp\" alt=\"\">\n            <p>This feature sanitizes the cold water tank, eliminating contaminants and protecting against biofilms.<\/p>\n          <\/div>\n        \n        <\/div>\n          \n      <\/div>\n\n      <div class=\"card right card2\">\n        \n        <div class=\"card-inner\">\n      \n          <div class=\"card-top\">\n          \n            <img src=\"https:\/\/cdn.shopify.com\/s\/files\/1\/0940\/1168\/7234\/files\/icon-2.svg\" alt=\"\">  \n            <h3>Touchless Dispense<\/h3>\n          \n          <\/div>\n\n          <div class=\"card-desc\">\n            \n            <img src=\"https:\/\/cdn.shopify.com\/s\/files\/1\/0940\/1168\/7234\/files\/Frame_561.png\" alt=\"\">  \n            <p>Conveniently dispenses water with a simple wave, making hydration completely touchless.<\/p>\n          \n          <\/div>\n        \n        <\/div>\n          \n      <\/div>\n      \n\n      <div class=\"card right card3\">\n        \n        <div class=\"card-inner\">\n      \n          <div class=\"card-top\">\n            <img src=\"https:\/\/cdn.shopify.com\/s\/files\/1\/0940\/1168\/7234\/files\/icon-3.svg\" alt=\"\">  \n            <h3>2× Fast Dispense<\/h3>\n          <\/div>  \n\n          <div class=\"card-desc\">\n            <img src=\"https:\/\/cdn.shopify.com\/s\/files\/1\/0940\/1168\/7234\/files\/Lago_Dealer_Exploded_Insets_1.png?v=1755803870\" alt=\"\">\n            <p>Delivers a fast 0.9&nbsp;GPM flow rate, twice as fast as the industry standard.<\/p>\n          <\/div>\n\n        <\/div>\n\n      <\/div>\n\n\n      <div class=\"card left card4\">\n        \n        <div class=\"card-inner\">\n      \n          <div class=\"card-top\">\n            <img src=\"https:\/\/cdn.shopify.com\/s\/files\/1\/0940\/1168\/7234\/files\/icon-4.svg\" alt=\"\">  \n            <h3>Tall Dispense Height<\/h3>\n          <\/div>\n          \n          <div class=\"card-desc\">\n            <img src=\"https:\/\/cdn.shopify.com\/s\/files\/1\/0940\/1168\/7234\/files\/Lago_Dealer_Exploded_Insets_1_xasxsa.png?v=1755803868\" alt=\"\">  \n            <p>A tall 14&nbsp;inch dispense height makes filling large bottles and pitchers effortless.<\/p>\n          <\/div>\n        \n        <\/div>\n\n      <\/div>\n      \n\n      <div class=\"card left card5\">\n        <div class=\"card-inner\">\n      \n          <div class=\"card-top\">\n            <img src=\"https:\/\/cdn.shopify.com\/s\/files\/1\/0940\/1168\/7234\/files\/icon-5.svg\" alt=\"\"> \n            <h3>5‑Stage RO with Mineralization<\/h3>\n          <\/div>\n          \n          <div class=\"card-desc\">\n            <img src=\"https:\/\/cdn.shopify.com\/s\/files\/1\/0940\/1168\/7234\/files\/asdxascas.png\" alt=\"\">  \n            <!--<p>Includes sediment, carbon, RO and post‑carbon filtration plus mineralization for crisp, clean taste.<\/p>-->\n            <div class=\"block\">\n                <p><strong>Stage 1: Sediment Filter<\/strong><\/p> \n                <p>Filters dust, rust, and particles.<\/p> \n                \n                <p><strong>Stage 2: Pre Carbon Filter<\/strong><\/p> \n                <p>Filters chlorine, VOCs, & other chemicals.<\/p> \n                \n                <p><strong>Stage 3: RO Membrane<\/strong><\/p>\n                <p>Blocks leads, arsenic, PFAS, and more.<\/p> \n                \n                <p><strong>Stage 4: Post Carbon Filter<\/strong><\/p>\n                <p>Filters residual bad tastes and impurities.<\/p> \n                \n                <p><strong>Stage 5: Mineralizing Filter<\/strong><\/p>\n                <p>Adds beneficial minerals like calcium, magnesium and potassium to water.<\/p>\n            <\/div>\n          <\/div>\n        \n        <\/div>\n\n      <\/div>\n\n    <\/div> <!-- end pinned-container -->\n    \n\n\n    <!-- Mobile controls: optional, shown via CSS only on ≤768px -->\n    <div class=\"mobile-controls\" aria-hidden=\"true\">\n      <button class=\"mc-btn mc-prev\" type=\"button\">Prev<\/button>\n      <div class=\"mc-dots\" role=\"tablist\" aria-label=\"Feature steps\">\n        <span class=\"mc-dot\" data-step=\"2\"><\/span>\n        <span class=\"mc-dot\" data-step=\"3\"><\/span>\n        <span class=\"mc-dot\" data-step=\"4\"><\/span>\n        <span class=\"mc-dot\" data-step=\"5\"><\/span>\n        <span class=\"mc-dot\" data-step=\"6\"><\/span>\n      <\/div>\n      <button class=\"mc-btn mc-next\" type=\"button\">Next<\/button>\n    <\/div>\n\n    \n  <\/div> <!-- end overlay -->\n\n  <!-- Feature sections follow. These provide scroll height to trigger\n     