{{ 'section-lago-4-col.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign section_heading = section.settings.heading | strip
-%}

<section class="lago-4-col color-{{ section.settings.color_scheme }} gradient">
  <div class="page-width section-{{ section.id }}-padding">
    {%- if section_heading != blank -%}
      <h2 class="lago-4-col__heading {{ section.settings.heading_size }}">{{ section_heading | escape }}</h2>
    {%- endif -%}

    <div class="lago-4-col__grid">
      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when 'card' -%}
            <article class="lago-4-col__card" {{ block.shopify_attributes }}>
              {%- if block.settings.image != blank -%}
                <div class="lago-4-col__media">
                  {{
                    block.settings.image
                    | image_url: width: 1200
                    | image_tag:
                      loading: 'lazy',
                      widths: '320, 480, 640, 800, 960, 1200',
                      sizes: '(min-width: 990px) 25vw, (min-width: 750px) 50vw, 100vw',
                      class: 'lago-4-col__image',
                      alt: block.settings.image.alt | default: block.settings.title
                  }}
                </div>
              {%- endif -%}

              <div class="lago-4-col__body">
                {%- if block.settings.title != blank -%}
                  <h3 class="lago-4-col__title">{{ block.settings.title | escape }}</h3>
                {%- endif -%}
                {%- if block.settings.text != blank -%}
                  <div class="lago-4-col__text rte">{{ block.settings.text }}</div>
                {%- endif -%}
              </div>
            </article>
        {%- endcase -%}
      {%- endfor -%}
    </div>
  </div>
</section>

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

{% schema %}
{
  "name": "Lago 4 col",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Hydration solutions packed with innovation"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading size",
      "options": [
        { "value": "h2", "label": "Small" },
        { "value": "h1", "label": "Medium" },
        { "value": "h0", "label": "Large" }
      ],
      "default": "h1"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Title"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Text",
          "default": "<p>Describe the feature in one or two sentences.</p>"
        }
      ]
    }
  ],
  "max_blocks": 8,
  "presets": [
    {
      "name": "Lago 4 col",
      "blocks": [
        { "type": "card" },
        { "type": "card" },
        { "type": "card" },
        { "type": "card" }
      ]
    }
  ]
}
{% endschema %}

