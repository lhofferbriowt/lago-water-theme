<script src="https://code.jquery.com/jquery-3.7.1.min.js" defer></script>
<script src="https://cdn.jsdelivr.net/npm/gsap@3.13.0/dist/gsap.min.js" defer></script>

<script src="https://cdn.jsdelivr.net/npm/gsap@3.13.0/dist/ScrollTrigger.min.js" defer></script>

<script>
document.addEventListener("DOMContentLoaded", function () {
    
  gsap.registerPlugin(ScrollTrigger);

const section = document.querySelector("#condenser");
const centerImage = section.querySelector(".condenser");
const pins = section.querySelectorAll(".pin");
const cards = section.querySelectorAll(".feature-card");

let tl = gsap.timeline({
  scrollTrigger: {
    trigger: section,
    start: "top top",
    end: "bottom bottom",
    scrub: true,
    markers: false
  },
  onComplete: () => {
    gsap.to(cards, {
      opacity: 1,
      x: 0,
      ease: "power1.inOut",
      duration: 0.6
    });
    gsap.to(
      pins,
      {
        opacity: 1,
        scale: 1,
        stagger: 0.1,
        duration: 0.6
      },
      "<"
    );
  }
});

tl.to(centerImage, {
  opacity: 1,
  scale: 1,
  ease: "none"
})
  .to(cards[2], {
    opacity: 1,
    x: 0,
    ease: "none"
  })
  .to(
    pins[0],
    {
      opacity: 1,
      scale: 1,
      ease: "none"
    },
    "<"
  )
  .to(cards[2], {
    delay: 0.3,
    opacity: 0,
    x: 40,
    ease: "none"
  })
  .to(
    pins[0],
    {
      opacity: 0,
      scale: 0.6,
      ease: "none"
    },
    "<"
  )
  .to(cards[3], {
    opacity: 1,
    x: 0,
    ease: "none"
  })
  .to(
    pins[1],
    {
      opacity: 1,
      scale: 1,
      ease: "none"
    },
    "<"
  )
  .to(cards[3], {
    delay: 0.3,
    opacity: 0,
    x: 40,
    ease: "none"
  })
  .to(
    pins[1],
    {
      opacity: 0,
      scale: 0.6,
      ease: "none"
    },
    "<"
  )
  .to(cards[4], {
    opacity: 1,
    x: 0,
    ease: "none"
  })
  .to(
    pins[2],
    {
      opacity: 1,
      scale: 1,
      ease: "none"
    },
    "<"
  )
  .to(cards[4], {
    delay: 0.3,
    opacity: 0,
    x: 40,
    ease: "none"
  })
  .to(
    pins[2],
    {
      opacity: 0,
      scale: 0.6,
      ease: "none"
    },
    "<"
  )
  .to(cards[0], {
    opacity: 1,
    x: 0,
    ease: "none"
  })
  .to(
    pins[3],
    {
      opacity: 1,
      scale: 1,
      ease: "none"
    },
    "<"
  )
  .to(cards[0], {
    delay: 0.3,
    opacity: 0,
    x: 40,
    ease: "none"
  })
  .to(
    pins[3],
    {
      opacity: 0,
      scale: 0.6,
      ease: "none"
    },
    "<"
  )
  .to(cards[1], {
    opacity: 1,
    x: 0,
    ease: "none"
  })
  .to(
    pins[4],
    {
      opacity: 1,
      scale: 1,
      ease: "none"
    },
    "<"
  )
  .to(cards[1], {
    delay: 0.3,
    opacity: 0,
    x: 40,
    ease: "none"
  })
  .to(
    pins[4],
    {
      opacity: 0,
      scale: 0.6,
      ease: "none"
    },
    "<"
  );

});

</script>








