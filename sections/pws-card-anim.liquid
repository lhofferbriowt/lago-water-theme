<style>
    .mobile-cond-app
    {
      display:none;
    }

    @media(max-width:980px)
    {

      .desktop-cond-app
      {
        display:none;
      }

      .mobile-cond-app
      {
        display:block;
      }

      .mobile-cond-app img 
      {
          width: 100%;
      }

      #text-sec {
          padding-top: 15px !important;
      }
    }

    .cst_wrap_css 
    {
    flex-direction: column;
    }

    .cst_wrap_css .cst_card_para {
    width: 100%;
    }

    .cst_wrap_css .cst_card_img {
    width: 200px;
    }

    .cst_card {
    max-width: fit-content;
    background: #d2d1d1;
    opacity: 1;
    transform: none;
    pointer-events: auto;
    transition: none;
    display: block;
    transition: opacity 0.3s ease, height 0.3s linear, margin 0.3s ease;
    will-change: transform, opacity, height;
    }

    .cst_top_wrapper {
    display: flex;
    gap: 20px;
    align-items: center;
    margin-bottom: 10px;
    }

    .cst_icon,
    .cst_card_heading {
    width: fit-content;
    }

    .cst_bottom_wrapper {
    display: flex;
    gap: 20px;
    }

    .cst_card_img {
    width: 125px;
    }

    .cst_card_para {
    width: 175px;
    text-align: left;
    }

    .spacer {
    height: 100vh;
    display: grid;
    place-items: center;
    color: #5b6b7c;
    background: linear-gradient(180deg, #fff, var(--bg));
    border-bottom: 1px solid #000;
    }

    .spacer.alt {
    background: linear-gradient(180deg, var(--bg), #fff);
    }

    /* Pinned / animated section */
    .condenser-wrap {
    position: relative;
    background: var(--bg);
    padding: 8vh 5vw;
    height:800vh;
    }

    .condenser-stage {
    max-width: 1200px;
    margin: 0 auto;
    position: sticky;
    top:0;
    display: grid;
    grid-template-columns: 1fr minmax(360px, 520px) 1fr;
    gap: 32px;
    align-items: center;
    min-height: 70vh;
    
    }

    /* Columns */
    .col {
    display: grid;
    gap: 18px;
    }

    .col.left {
    justify-items: end;
    }
    .col.right {
    justify-items: start;
    }

    /* Feature cards */
    .feature-card {
    width: min(360px, 90%);
    padding: 18px 18px 18px 18px;
    box-shadow: var(--shadow);
    gap: 12px;
    opacity: 0;
    transform: translateX(40px);
    width: 360px;
    max-width: fit-content;
    background: #d2d1d1;
    padding: 20px;
    opacity: 0;
    transform: translateX(40px);
    pointer-events: auto;
    transition: none;
    display: block;
    will-change: transform, opacity, height;
    }
    .col.left .feature-card {
    transform: translateX(-40px);
    }

    .icon {
    width: 64px;
    height: 64px;
    display: grid;
    place-items: center;
    font-weight: 700;
    }
    .feature-card h3 {
    margin: 2px 0 4px 0;
    font-size: 18px;
    color: #50585b;
    }
    .feature-card p {
    margin: 0;
    font-size: 15px;
    color: #50585b;
    }

    .center {
    position: relative;
    display: grid;
    place-items: center;
    min-height: 560px;
    border-radius: 22px;
    overflow: hidden;
    }
    .condenser {
    position: relative;
    width: 100%;
    aspect-ratio: 4/6;
    opacity: 0.3;
    transform: scale(0.94);
    }

    .pin {
    position: absolute;
    width: 30px;
    height: 30px;
    border-radius: 999px;
    background: rgba(53, 113, 181, 0.85);
    box-shadow: 0 0 0 0 var(--pin-shadow);
    transform: scale(0.6);
    opacity: 0;
    pointer-events: none;
    }

    /* Demo pin positions (tweak as needed for your real asset) */
    .pin.p1 {
    top: 3.5%;
    left: 41%;
    }
    .pin.p2 {
    top: 15%;
    left: 92%;
    }
    .pin.p3 {
    top: 24%;
    left: 74%;
    }
    .pin.p4 {
    top: 36%;
    left: 74%;
    }
    .pin.p5 {
    top: 62%;
    left: 34%;
    }

    /* Responsiveness */
    @media (max-width: 980px) {
    .condenser-stage {
        grid-template-columns: 1fr;
        gap: 26px;
    }
    .col.left,
    .col.right {
        justify-items: stretch;
    }
    .feature-card {
        width: 100%;
    }
    }

</style>


