{{ 'section-lago-home-1-5.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign product_blocks = section.blocks | where: 'type', 'product_path'
  assign value_blocks = section.blocks | where: 'type', 'dealer_value'
-%}

<div
  class="lago-home-1-5 lago-collection-content"
  style="--l15-path-label-font-size: {{ section.settings.path_card_label_font_size }}px; --l15-path-label-font-weight: {% if section.settings.path_card_label_bold %}600{% else %}400{% endif %}; --l15-section-title-font-size: {{ section.settings.section_title_font_size }}px; --l15-dealer-heading-font-size: {{ section.settings.dealer_heading_font_size }}px; --l15-value-row-title-font-size: {{ section.settings.value_row_title_font_size }}px; --l15-value-row-text-font-size: {{ section.settings.value_row_text_font_size }}px;"
>
  <div class="lago-home-1-5__inner">
    <section class="l15-solutions" aria-labelledby="l15-solutions-heading">
      <h2 id="l15-solutions-heading" class="l15-section-title">{{ section.settings.solutions_heading | escape }}</h2>
      <div class="l15-path-grid">
        {%- for block in product_blocks -%}
          <a
            class="l15-path-card"
            href="{{ block.settings.link | default: '#' }}"
            {{ block.shopify_attributes }}
          >
            <div class="l15-path-card__img">
              {%- if block.settings.image != blank -%}
                {%- assign l15_path_alt = block.settings.image.alt | default: block.settings.title -%}
                {{
                  block.settings.image
                  | image_url: width: 480
                  | image_tag: loading: 'lazy', sizes: '(max-width: 749px) 45vw, 28vw', widths: '240, 360, 480', alt: l15_path_alt
                }}
              {%- else -%}
                <span class="l15-path-card__placeholder" aria-hidden="true"></span>
              {%- endif -%}
            </div>
            <span class="l15-path-card__label">{{ block.settings.title | escape }}</span>
          </a>
        {%- endfor -%}
      </div>
    </section>

    <section class="l15-dealer-values" aria-labelledby="l15-dealer-heading">
      <h2 id="l15-dealer-heading" class="l15-dealer-values__title">{{ section.settings.dealer_section_heading | escape }}</h2>
      <div class="l15-dealer-values__grid">
        {%- for block in value_blocks -%}
          <div class="l15-value-row" {{ block.shopify_attributes }}>
            <div class="l15-value-row__icon">
              {%- if block.settings.icon != blank -%}
                {%- assign l15_icon_alt = block.settings.icon.alt | default: block.settings.title -%}
                {{
                  block.settings.icon
                  | image_url: width: 120
                  | image_tag: loading: 'lazy', widths: '60, 120', alt: l15_icon_alt
                }}
              {%- endif -%}
            </div>
            <div>
              <h3 class="l15-value-row__title">{{ block.settings.title | escape }}</h3>
              <p class="l15-value-row__text">{{ block.settings.text | escape }}</p>
            </div>
          </div>
        {%- endfor -%}
      </div>
      {%- if section.settings.dealer_cta_label != blank -%}
        <div class="l15-dealer-values__cta">
          <a class="l15-btn" href="{{ section.settings.dealer_cta_link | default: '#' }}">{{ section.settings.dealer_cta_label | escape }}</a>
        </div>
      {%- endif -%}
    </section>
  </div>
</div>

{% schema %}
{
  "name": "Lago 1.5 collection content",
  "tag": "section",
  "class": "section section-lago-collection-content",
  "enabled_on": {
    "templates": ["collection"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Explore solutions"
    },
    {
      "type": "text",
      "id": "solutions_heading",
      "label": "Heading",
      "default": "Explore Our Solutions"
    },
    {
      "type": "range",
      "id": "section_title_font_size",
      "min": 12,
      "max": 60,
      "step": 1,
      "unit": "px",
      "label": "Explore solutions heading font size",
      "default": 15
    },
    {
      "type": "range",
      "id": "path_card_label_font_size",
      "min": 8,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Solution card label font size",
      "default": 12
    },
    {
      "type": "checkbox",
      "id": "path_card_label_bold",
      "label": "Bold solution card labels",
      "default": false
    },
    {
      "type": "header",
      "content": "Dealer network"
    },
    {
      "type": "text",
      "id": "dealer_section_heading",
      "label": "Heading",
      "default": "Join the Lago Dealer Network"
    },
    {
      "type": "range",
      "id": "dealer_heading_font_size",
      "min": 12,
      "max": 60,
      "step": 1,
      "unit": "px",
      "label": "Dealer heading font size",
      "default": 16
    },
    {
      "type": "range",
      "id": "value_row_text_font_size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Dealer value description font size",
      "default": 16
    },
    {
      "type": "range",
      "id": "value_row_title_font_size",
      "min": 12,
      "max": 28,
      "step": 1,
      "unit": "px",
      "label": "Dealer value title font size",
      "default": 16
    },
    {
      "type": "text",
      "id": "dealer_cta_label",
      "label": "Button label",
      "default": "Become a Dealer"
    },
    {
      "type": "url",
      "id": "dealer_cta_link",
      "label": "Button link"
    }
  ],
  "blocks": [
    {
      "type": "product_path",
      "name": "Solution card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Countertop dispensers"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    },
    {
      "type": "dealer_value",
      "name": "Dealer benefit",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Factory direct partner"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Description",
          "default": "Dealers get access to the largest selection of water dispensers and filtration systems."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Lago 1.5 collection content",
      "blocks": [
        {
          "type": "product_path",
          "settings": {
            "title": "Countertop Dispensers"
          }
        },
        {
          "type": "product_path",
          "settings": {
            "title": "Sparkling Dispensers"
          }
        },
        {
          "type": "product_path",
          "settings": {
            "title": "Stand Up Dispensers"
          }
        },
        {
          "type": "product_path",
          "settings": {
            "title": "Ice Makers"
          }
        },
        {
          "type": "dealer_value",
          "settings": {
            "title": "Factory Direct Partner",
            "text": "Dealers get access to the largest selection of water dispensers and filtration systems."
          }
        },
        {
          "type": "dealer_value",
          "settings": {
            "title": "Dedicated Representative",
            "text": "Lago customer service representatives are ready to help and act as an extension of your team."
          }
        }
      ]
    }
  ]
}
{% endschema %}
