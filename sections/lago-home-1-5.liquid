          }
        },
        {
          "type": "product_path",
          "settings": {
            "title": "Stand Up Dispensers"
          }
        },
        {
          "type": "product_path",
          "settings": {
            "title": "Ice Makers"
          }
        },
        {
          "type": "product_path",
          "settings": {
            "title": "Undersink Filtration Systems"
          }
        },
        {
          "type": "product_path",
          "settings": {
            "title": "Light Commercial RO Systems"
          }
        },
        {
          "type": "product_path",
          "settings": {
            "title": "Point-of-Entry Filtration Systems"
          }
        },
        {
          "type": "product_path",
          "settings": {
            "title": "Industrial RO Systems"
          }
        },
        {
          "type": "dealer_value",
          "settings": {
            "title": "Factory Direct Partner",
            "text": "Dealers get access to the largest selection of water dispensers and filtration systems."
          }
        },
        {
          "type": "dealer_value",
          "settings": {
            "title": "Dedicated Representative",
            "text": "Lago customer service representatives are ready to help and act as an extension of your team."
          }
        },
        {
          "type": "dealer_value",
          "settings": {
            "title": "Expedited Shipping",
            "text": "Our Lago distribution centers are located nationwide."
          }
        },
        {
          "type": "dealer_value",
