        },
        {
          "type": "textarea",
          "id": "title",
          "label": "Title (line breaks allowed)",
          "default": "POU RO+\nDispensers"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Lago 1.5 homepage",
      "blocks": [
        {
          "type": "product_path",
          "settings": {
            "title": "Countertop Dispensers"
          }
        },
        {
