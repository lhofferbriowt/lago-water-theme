    {
      "type": "range",
      "id": "value_row_title_font_size",
      "min": 12,
      "max": 28,
      "step": 1,
      "unit": "px",
      "label": "Dealer value title font size",
      "default": 16
    },
    {
      "type": "text",
      "id": "dealer_cta_label",
      "label": "Button label",
      "default": "Become a Dealer"
    },
    {
      "type": "url",
      "id": "dealer_cta_link",
      "label": "Button link"
    },
    {
      "type": "header",
      "content": "Hydration / categories"
    },
    {
      "type": "range",
      "id": "cat_label_font_size",
      "min": 10,
      "max": 28,
      "step": 1,
      "unit": "px",
      "label": "Category label font size",
      "default": 16
    },
    {
      "type": "text",
      "id": "innovation_heading",
      "label": "Heading",
      "default": "Hydration innovation is what we do."
    },
    {
      "type": "range",
      "id": "innovation_heading_font_size",
      "min": 12,
      "max": 60,
      "step": 1,
      "unit": "px",
      "label": "Innovation heading font size",
      "default": 16
    },
    {
      "type": "textarea",
      "id": "innovation_lead",
      "label": "Supporting text",
      "default": "We provide our dealers the largest product offering in the industry with the most advanced technology."
    },
    {
      "type": "range",
      "id": "innovation_lead_font_size",
      "min": 12,
      "max": 32,
      "step": 1,
      "unit": "px",
      "label": "Innovation lead font size",
      "default": 16
    },
    {
      "type": "text",
      "id": "innovation_cta_label",
      "label": "Button label",
      "default": "Learn More"
    },
    {
      "type": "url",
      "id": "innovation_cta_link",
      "label": "Button link"
    }
  ],
  "blocks": [
    {
      "type": "product_path",
      "name": "Solution card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Countertop dispensers"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    },
    {
      "type": "dealer_value",
      "name": "Dealer benefit",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Factory direct partner"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Description",
          "default": "Dealers get access to the largest selection of water dispensers and filtration systems."
