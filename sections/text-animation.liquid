    <section class="cst_text_animation" id="text-sec">
        <div class="containers">
            <div class="tt-text-reveal" data-highlight-text  data-highlight-scroll-end="bottom 20%" data-highlight-scroll-start="top 50%" data-highlight-stagger="0.5">
                Have you ever felt you have no other option?<span class="spacer"></span>
                Lago was founded with a vision to empower entrepreneurs entering the water industry by providing the essential tools and solutions they need to achieve true financial freedom.<span class="spacer"></span>
                Our mission is to help every consumer hydrate happier, healthier and contribute to building a better planet.<span class="spacer"></span>
                Together we're building a community of changemakers - people who believe in creating a brighter, cleaner future. With every sip, you are supporting a more sustainable world.<span class="spacer"></span>
                <span class="lago-span">Lago is the leader in innovative pure water solutions.</span>
            </div>
        </div>
    </section>
   
    
    <!-- Scripts -->
    <script src="https://code.jquery.com/jquery-3.7.1.min.js" defer></script>
    <script src="https://cdn.jsdelivr.net/npm/gsap@3.13.0/dist/gsap.min.js" defer></script>

    <script src="https://cdn.jsdelivr.net/npm/gsap@3.13.0/dist/ScrollTrigger.min.js" defer></script>
    <script src="https://cdn.jsdelivr.net/npm/gsap@3.13.0/dist/SplitText.min.js" defer></script>
   

    <script>

        document.addEventListener("DOMContentLoaded", () => {
            gsap.registerPlugin(ScrollTrigger, SplitText);
            initHighlightText();
        })
        
        function initHighlightText(){

            let splitHeadingTargets = document.querySelectorAll("[data-highlight-text]")
            
            splitHeadingTargets.forEach((heading) => {

                const scrollStart = heading.getAttribute("data-highlight-scroll-start") || "top 90%"
                const scrollEnd = heading.getAttribute("data-highlight-scroll-end") || "center 40%"
                const fadedValue = heading.getAttribute("data-highlight-fade") || 0.2 // Opacity of letter
                const staggerValue =  heading.getAttribute("data-highlight-stagger") || 0.1 // Smoother reveal

                new SplitText(heading, {
                    type: "words, chars",
                    autoSplit: true,
                    onSplit(self) {
                    let ctx = gsap.context(() => {
                        let tl = gsap.timeline({
                        scrollTrigger: {
                            scrub: true,
                            trigger: heading, 
                            start: scrollStart,
                            end: scrollEnd,
                            markers: false
                        }
                        })
                        tl.from(self.words,{
                            autoAlpha: fadedValue,
                            stagger: staggerValue,
                            ease: "linear"
                        })
                    });
                        return ctx; // return our animations so GSAP can clean them up when onSplit fires
                }
                });    
            });
        }

    </script>

