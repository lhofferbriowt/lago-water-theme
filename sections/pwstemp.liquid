<style>
  .reveal-section 
  {
      width: 100%;
      padding: 8vh 4vw 0 4vw;
      box-sizing: border-box;
      display: flex;
      justify-content: center;
  }

  .reveal-wrapper {
    padding-bottom: 5vh;
    font-size: 70px;
    line-height: 96px;
    font-weight: 300;
    font-family: "CentraNo Book", sans-serif !important;
    margin: 0 auto;
    width: 75%;
  }

  .reveal-line {
    font-size: clamp(var(--font-min), 4vw + 1rem, var(--font-max));
    line-height: clamp(var(--line-height-min), 2vh + 1.1, var(--line-height-max));
    font-weight: 300;
    margin: 0 0 1em 0; 
    padding: 0;
    transform: translateY(10px);
    will-change: transform;
  }

  @media (prefers-reduced-motion: reduce) {
    .reveal-line {
      transform: none;
      transition: opacity 0.18s linear, color 0.18s linear;
    }
  }

  .reveal-line.active {
    opacity: 1;
    transform: translateY(0);
    color: var(--active-colour, var(--color-active));
  }

  .reveal-word {
    display: inline-block;
    opacity: 0.25;
    color: var(--color-inactive);
    will-change: opacity, color;
    transition: none;
  }
</style>


