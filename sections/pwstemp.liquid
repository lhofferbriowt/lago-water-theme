<script>
  // original js script.js — Water Cooler Feature Animation (spacer-aware)

  document.addEventListener('DOMContentLoaded', () => {

    const introCooler = document.querySelector('.intro-cooler');

    // Grab cards and pins in display order
    /*const cardElems = [
      document.querySelector('.card1'),
      document.querySelector('.card2'),
      document.querySelector('.card3'),
      document.querySelector('.card4'),
      document.querySelector('.card5'),
    ];*/

    const cardElems = [
      document.querySelector('.card1'),
      document.querySelector('.card2'),
      document.querySelector('.card3'),
      document.querySelector('.card4'),
      document.querySelector('.card5'),
    ].filter(Boolean);
    
    // Use card count + 2 (blank step + final “all cards” step)
    let FEATURES_COUNT = cardElems.length + 2;
    let ALL_STEP       = FEATURES_COUNT;


    const pinElems = [
      document.querySelector('.pin1'),
      document.querySelector('.pin2'),
      document.querySelector('.pin3'),
      document.querySelector('.pin4'),
      document.querySelector('.pin5'),
    ];

    function setPinsHidden(hidden) {
      pinElems.forEach(pin => {
        if (pin) pin.style.opacity = hidden ? 0 : '';
      });
    }

    // Gather sections and overlay
    const sections = Array.from(document.querySelectorAll('section.section'));
    const overlay  = document.getElementById('overlay');

    // Feature sections (those with data-index)
    const featureSections = Array.from(
      document.querySelectorAll('section[data-index]')
    );

    // First look for a spacer; if none, fall back to .main-anim
    // The spacer uses its bottom edge as the start of the band
    const spacerEl   = document.querySelector('.anim-trigger-spacer');
    const mainAnimEl = document.querySelector('.main-anim');
    const featureStartEl = spacerEl || mainAnimEl;

    // Determine total number of feature steps dynamically
    //let FEATURES_COUNT = featureSections.length || 7;
    //let ALL_STEP       = FEATURES_COUNT;

    // State and constants
    let lastIndex      = 0;
    let mode           = 'forward';
    let lastStepChange = 0;
    const MIN_STEP_INTERVAL = 260;

    function setOverlayVisible(visible) {
      if (!overlay) return;
      if (visible) {
        overlay.classList.add('visible');
        jQuery('.lago-text,.tt-text-reveal').hide();
      } else {
        overlay.classList.remove('visible');
        jQuery('.lago-text,.tt-text-reveal').show();
      }
    }

    function showCards(indices) {
      const showAll = indices.length === pinElems.length;

      cardElems.forEach((card, idx) => {
        const cardIndex = idx + 1;
        if (indices.includes(cardIndex)) {
          card?.classList.add('active');
        } else {
          card?.classList.remove('active');
        }
      });

      pinElems.forEach((pin, idx) => {
        const pinIndex = idx + 1;
        if (indices.includes(pinIndex)) {
          pin.style.visibility = 'visible';
          if (indices.length === 1 || showAll) {
            pin.classList.add('blink');
          }
        } else {
          pin.style.visibility = 'hidden';
          pin.classList.remove('blink');
        }
      });
    }

    function calculateSectionIndex() {
      const vh   = window.innerHeight;
      const topY = window.pageYOffset;

      // Grab a reference to the very first section inside main-anim (the headline)
      const introSection = document.querySelector('.main-anim > .section:first-child');

      // Determine the start of the feature band
      let featuresStart;
      
      if (featureStartEl) {
        if (featureStartEl === spacerEl) {
          // If using a spacer, start when the intro section is halfway scrolled
          // Adjust the ratio (0.5) to change when the overlay appears (0 = immediately, 1 = after intro disappears)
          const RATIO = 0.5;
          if (introSection) {
            const introTop    = introSection.offsetTop;
            const introHeight = introSection.offsetHeight;
            featuresStart = introTop + introHeight * RATIO - vh * RATIO - 250;
          } else {
            // Fallback to original behaviour if no intro section is found
            featuresStart = featureStartEl.offsetTop + featureStartEl.offsetHeight;
          }
        } else {
          // Start at the top of .main-anim if no spacer
          featuresStart = featureStartEl.offsetTop;
        }
      } else {
        // Original fallback sequence...
        const intro = document.getElementById('text-sec');
        if (intro) {
          featuresStart = intro.offsetTop + intro.offsetHeight - 250;
        } else {
          const animSec = document.getElementById('anim-sec');
          if (animSec) {
            featuresStart = animSec.offsetTop;
          } else if (featureSections.length > 0) {
            featuresStart = featureSections[0].offsetTop;
          } else {
            featuresStart = sections[1]?.offsetTop ?? 0;
          }
        }
      }



      
      /*if (featureStartEl) {
        if (featureStartEl === spacerEl) {
          // Start after the spacer is completely scrolled past
          featuresStart = featureStartEl.offsetTop + featureStartEl.offsetHeight;
        } else {
          // Start at the top of .main-anim if no spacer
          featuresStart = featureStartEl.offsetTop;
        }
      } else {
        // Fallback sequence: bottom of #text-sec → top of #anim-sec → first data-index
        const intro = document.getElementById('text-sec');
        if (intro) {
          featuresStart = intro.offsetTop + intro.offsetHeight;
        } else {
          const animSec = document.getElementById('anim-sec');
          if (animSec) {
            featuresStart = animSec.offsetTop;
          } else if (featureSections.length > 0) {
            featuresStart = featureSections[0].offsetTop;
          } else {
            featuresStart = sections[1]?.offsetTop ?? 0;
          }
        }
      }*/

      // Compute end of the band
      const featuresEnd = featuresStart + FEATURES_COUNT * vh;

      if (topY < featuresStart) return 0;
      if (topY >= featuresEnd) return FEATURES_COUNT + 1;

      const relative = topY - featuresStart;
      const idx      = Math.floor(relative / vh) + 1;
      return Math.max(1, Math.min(FEATURES_COUNT, idx));
    }

    /*function updateState(newIndex, currentMode) {
      const mobile = window.matchMedia('(max-width: 768px)').matches;
      const introCooler = document.querySelector('.intro-cooler');
      
      // On desktop, control the blank cooler’s zoom and visibility
      if (!mobile && introCooler) {
        if (newIndex <= 1) {
          // Step 1: show normally, no zoom
          introCooler.classList.remove('zoom');
          introCooler.classList.remove('hidden');
        } else if (newIndex === 2) {
          // Step 2: apply slight zoom while overlay/card 1 appears
          introCooler.classList.add('zoom');
          introCooler.classList.remove('hidden');
        } else {
          // Beyond step 2: hide the intro image
          introCooler.classList.add('hidden');
        }
      }

      // Show the overlay only from step 2 onwards
      setOverlayVisible(newIndex >= 2 && newIndex <= ALL_STEP);  


      //setOverlayVisible(newIndex >= 1 && newIndex <= ALL_STEP);

      if (mobile) {
        if (newIndex === 1) {
          showCards([]);
          setPinsHidden(false);
        } else if (newIndex >= 2 && newIndex <= ALL_STEP) {
          const cardNum = (newIndex === ALL_STEP ? 5 : (newIndex - 1));
          showCards([cardNum]);
          setPinsHidden(true);
        } else {
          showCards([]);
          setPinsHidden(false);
        }
        return;
      }

      if (currentMode === 'forward') {
        if (newIndex === 1) {
          showCards([]);
        } else if (newIndex >= 2 && newIndex <= (ALL_STEP - 1)) {
          showCards([newIndex - 1]);
        } else if (newIndex === ALL_STEP) {
          showCards([1, 2, 3, 4, 5]);
        } else {
          showCards([]);
        }
      } else {
        if (newIndex === ALL_STEP) {
          showCards([1, 2, 3, 4, 5]);
        } else if (newIndex >= 2 && newIndex <= (ALL_STEP - 1)) {
          const visible = Array.from({ length: newIndex - 1 }, (_, i) => i + 1);
          showCards(visible);
        } else {
          showCards([]);
        }
      }
    }*/

    function updateState(newIndex, currentMode) {
      const mobile = window.matchMedia('(max-width: 768px)').matches;
      const introCooler = document.querySelector('.intro-cooler');

      // Hide the intro image when the main animation kicks in
      if (introCooler) {
        if (newIndex >= 1) {
          introCooler.classList.add('hidden');
        } else {
          introCooler.classList.remove('hidden');
        }
      }

      // Show the overlay from the very first step so the central image appears
      setOverlayVisible(newIndex >= 1 && newIndex <= ALL_STEP);

      if (mobile) {
        if (newIndex === 1) {
          // Mobile: show no cards yet (just the cooler)
          showCards([]);
          setPinsHidden(false);
        } else if (newIndex >= 2 && newIndex <= ALL_STEP) {
          const cardNum = (newIndex === ALL_STEP ? 5 : (newIndex - 1));
          showCards([cardNum]);
          setPinsHidden(true);
        } else {
          showCards([]);
          setPinsHidden(false);
        }
        return;
      }

      // Desktop: same logic as originally
      if (currentMode === 'forward') {
        if (newIndex === 1) {
          // Step 1: no cards – just the cooler image
          showCards([]);
        } else if (newIndex >= 2 && newIndex <= (ALL_STEP - 1)) {
          showCards([newIndex - 1]);
        } else if (newIndex === ALL_STEP) {
          showCards([1, 2, 3, 4, 5]);
        } else {
          showCards([]);
        }
      } else {
        if (newIndex === ALL_STEP) {
          showCards([1, 2, 3, 4, 5]);
        } else if (newIndex >= 2 && newIndex <= (ALL_STEP - 1)) {
          const visible = Array.from({ length: newIndex - 1 }, (_, i) => i + 1);
          showCards(visible);
        } else {
          showCards([]);
        }
      }
    }





    function handleScroll() {
      const now    = performance.now();
      const newIdx = calculateSectionIndex();

      if (newIdx !== lastIndex) {
        const atBoundary =
          (newIdx <= 1) || (newIdx === ALL_STEP) ||
          (lastIndex <= 1) || (lastIndex === ALL_STEP) ||
          (newIdx >= ALL_STEP + 1) || (lastIndex >= ALL_STEP + 1);
        if (!atBoundary && (now - lastStepChange < MIN_STEP_INTERVAL)) return;
        lastStepChange = now;

        if (mode === 'forward') {
          if (newIdx < lastIndex && lastIndex === ALL_STEP && newIdx <= (ALL_STEP - 1)) {
            mode = 'reverse';
          }
        } else {
          if (newIdx > lastIndex && newIdx === ALL_STEP) {
            mode = 'forward';
          }
        }

        if (newIdx <= 1 || newIdx >= ALL_STEP + 1) {
          mode = 'forward';
        }

        updateState(newIdx, mode);
        lastIndex = newIdx;
      }
    }

    // Initialise
    showCards([]);
    setOverlayVisible(false);
    window.addEventListener('scroll', handleScroll, { passive: true });
    window.addEventListener('resize', handleScroll);
    handleScroll();

    // ====== Mobile controls (unchanged except for dynamic ALL_STEP) ======
    (function () {
      const isMobile = () => window.matchMedia('(max-width: 768px)').matches;

      function ensureMobileControls() {
        if (!isMobile()) return null;
        const overlayEl = document.getElementById('overlay');
        if (!overlayEl) return null;
        let controls = overlayEl.querySelector('.mobile-controls');
        if (!controls) {
          controls = document.createElement('div');
          controls.className = 'mobile-controls';
          controls.setAttribute('aria-hidden', 'true');

          const prev = document.createElement('button');
          prev.className = 'mc-btn mc-prev';
          prev.type      = 'button';
          prev.textContent = 'Prev';

          const dots = document.createElement('div');
          dots.className = 'mc-dots';
          dots.setAttribute('role', 'tablist');
          dots.setAttribute('aria-label', 'Feature steps');

          for (let step = 2; step <= ALL_STEP; step++) {
            const dot = document.createElement('span');
            dot.className = 'mc-dot';
            dot.dataset.step = String(step);
            dots.appendChild(dot);
          }

          const next = document.createElement('button');
          next.className = 'mc-btn mc-next';
          next.type      = 'button';
          next.textContent = 'Next';

          controls.appendChild(prev);
          controls.appendChild(dots);
          controls.appendChild(next);
          overlayEl.appendChild(controls);
        }
        return controls;
      }

      function clampStep(s) {
        const maxStep = ALL_STEP + 1;
        return Math.max(0, Math.min(maxStep, s));
      }

      function reflectDots(idx) {
        const dots = Array.from(document.querySelectorAll('.mc-dot'));
        dots.forEach(d => {
          d.classList.toggle('is-active', Number(d.dataset.step) === idx);
        });
      }

      function goToStep(target) {
        const newIdx = clampStep(target);
        if (mode === 'forward') {
          if (newIdx < lastIndex && lastIndex === ALL_STEP && newIdx <= (ALL_STEP - 1)) {
            mode = 'reverse';
          }
        } else {
          if (newIdx > lastIndex && newIdx === ALL_STEP) {
            mode = 'forward';
          }
        }
        updateState(newIdx, mode);
        lastIndex = newIdx;
        reflectDots(newIdx);
      }

      // touch swipe handlers as before...
      let touchStartY   = null;
      const SWIPE_THRESHOLD = 28;
      function onTouchStart(e) {
        if (!isMobile()) return;
        touchStartY = e.changedTouches[0].clientY;
      }
      function onTouchEnd(e) {
        if (!isMobile() || touchStartY === null) return;
        const dy  = e.changedTouches[0].clientY - touchStartY;
        const now = performance.now();
        if (now - lastStepChange < MIN_STEP_INTERVAL) {
          touchStartY = null;
          return;
        }
        lastStepChange = now;
        if (Math.abs(dy) > SWIPE_THRESHOLD) {
          if (dy < 0) {
            goToStep(lastIndex + 1);
          } else {
            goToStep(lastIndex - 1);
          }
        }
        touchStartY = null;
      }

      function onNext() { if (isMobile()) goToStep(lastIndex + 1); }
      function onPrev() { if (isMobile()) goToStep(lastIndex - 1); }
      function onDot(e) {
        if (!isMobile()) return;
        const step = Number(e.currentTarget.dataset.step);
        if (!Number.isNaN(step)) goToStep(step);
      }

      function syncBodyScrollLock() {
        const overlayEl = document.getElementById('overlay');
        const lock      = isMobile() && overlayEl && overlayEl.classList.contains('visible');
        document.body.style.overscrollBehaviorY = lock ? 'contain' : '';
        document.body.style.touchAction         = lock ? 'manipulation' : '';
      }

      function wirePinTaps() {
        if (!isMobile()) return;
        pinElems.forEach((pin, idx) => {
          if (!pin) return;
          pin.addEventListener('click', () => goToStep(2 + idx));
        });
      }

      const controls = ensureMobileControls();
      if (controls) {
        const nextBtn  = controls.querySelector('.mc-next');
        const prevBtn  = controls.querySelector('.mc-prev');
        const dotElems = Array.from(controls.querySelectorAll('.mc-dot'));
        if (nextBtn) nextBtn.addEventListener('click', onNext);
        if (prevBtn) prevBtn.addEventListener('click', onPrev);
        dotElems.forEach(dot => dot.addEventListener('click', onDot));
      }

      document.addEventListener('touchstart', onTouchStart, { passive: true });
      document.addEventListener('touchend', onTouchEnd,   { passive: true });
      window.addEventListener('resize', syncBodyScrollLock);
      window.addEventListener('scroll', syncBodyScrollLock);

      reflectDots(lastIndex);
      syncBodyScrollLock();
      wirePinTaps();
    })();
  });


</script>

