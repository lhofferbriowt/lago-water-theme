{%- comment -%}
  Lago product specifications (Brio-inspired layout, Dawn styling).

  Metaobject `lago_specs_dispenser_10_6` (product metafield `custom.lago_specs_dispenser_10_6`):
  - model, cleaning_system, water_temp, flow_rate, product_dim_wdh, hot_tank_volume,
    heating_capacity, heating_power, cold_tank_volume, glycol_tank, combined_cooling_system,
    cooling_capacity, cooling_power  (single line text each)
  - Optional on same entry: display_title, manual_url (URL), supporting_image (image)

  Metaobject `lago_specs_dispenser_5_4` (product metafield `custom.lago_specs_5_4`):
  - item_no, model, cleaning_system, water_temp, flow_rate, product_dim_wdh, packing_dim_wdh,
    net_weight, pallet_qty, container_qty
  - Optional: display_title, manual_url, supporting_image

  Other families: shared optional fields — display_title, dimensions (pipes), additional_specs (pipes),
  spec_rows (list of lago_spec_row), materials, manual_url, supporting_image — see case branches.

  Product metafields (namespace custom): lago_specs_dispenser_10_6, lago_specs_5_4 (5-4 line),
  lago_specs_sparkling_countertop, lago_specs_sparkling_undersink, lago_specs_ice_scoop,
  lago_specs_ice_modular — each references its definition.

  Sparkling countertop (`lago_specs_sparkling_countertop`): item_no, flow_rate, dimensions_wdh, weight, pallet_qty
  Sparkling undersink (`lago_specs_sparkling_undersink`): item_no, flow_rate, tap_tower_dimensions_wdh,
    system_dimensions, tap_tower_system_weight, pallet_qty
  Ice scoop (`lago_specs_ice_scoop`): item_no, dimensions_lwh, ice_output, ice_shape, bin_capacity, compressor,
    voltage, power, condenser_unit, refrigerant, net_weight, gross_weight, carton_dimensions_lwh
  Ice modular (`lago_specs_ice_modular`): item_no_ice_maker_head, item_no_ice_storage_bin, overall_dimensions_lwh,
    ice_maker_head_lwh, ice_storage_bin_lwh, ice_output, ice_storage_bin_capacity, ice_shape, compressor, voltage_v_hz,
    power, condenser_unit, refrigerant, ice_maker_head_net_weight, ice_maker_head_gross_weight,
    ice_storage_bin_net_weight, ice_storage_bin_gross_weight, ice_maker_head_packing_dim, ice_storage_bin_packing_dim,
    loading_qty  (if packing dim handles in Admin differ, align handles there with Liquid)
{%- endcomment -%}

{{ 'section-lago-product-specs.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign family = section.settings.product_family
  assign specs = nil

  case family
    when 'dispenser_10_6'
      assign specs = product.metafields.custom.lago_specs_dispenser_10_6.value
    when 'dispenser_5_4'
      assign specs = product.metafields.custom.lago_specs_5_4.value
    when 'sparkling_countertop'
      assign specs = product.metafields.custom.lago_specs_sparkling_countertop.value
    when 'sparkling_undersink'
      assign specs = product.metafields.custom.lago_specs_sparkling_undersink.value
    when 'ice_scoop'
      assign specs = product.metafields.custom.lago_specs_ice_scoop.value
    when 'ice_modular'
      assign specs = product.metafields.custom.lago_specs_ice_modular.value
    when 'modular_ice_dispenser'
      assign specs = product.metafields.custom.lago_specs_modular_ice_dispenser.value
  endcase

  assign spec_rows_count = 0
  if specs != blank and specs.spec_rows != blank and specs.spec_rows.value != blank
    assign spec_rows_count = specs.spec_rows.value.size
  endif

  assign has_dimensions = false
  if specs != blank and specs.dimensions != blank
    assign has_dimensions = true
  endif

  assign has_additional = false
  if specs != blank and specs.additional_specs != blank
    assign has_additional = true
  endif

  assign has_materials = false
  if specs != blank and specs.materials != blank
    assign has_materials = true
  endif

  assign has_manual = false
  if specs != blank and specs.manual_url != blank
    assign has_manual = true
  endif

  assign has_features_column = false
  if spec_rows_count > 0 or has_additional or has_materials or has_manual
    assign has_features_column = true
  endif

  assign dispenser_10_6_visible = false
  if family == 'dispenser_10_6' and specs != blank
    if specs.model != blank or specs.cleaning_system != blank or specs.water_temp != blank or specs.flow_rate != blank or specs.product_dim_wdh != blank or specs.hot_tank_volume != blank or specs.heating_capacity != blank or specs.heating_power != blank or specs.cold_tank_volume != blank or specs.glycol_tank != blank or specs.combined_cooling_system != blank or specs.cooling_capacity != blank or specs.cooling_power != blank or specs.manual_url != blank or specs.supporting_image != blank
      assign dispenser_10_6_visible = true
    endif
  endif

  assign dispenser_5_4_visible = false
  if family == 'dispenser_5_4' and specs != blank
    if specs.item_no != blank or specs.model != blank or specs.cleaning_system != blank or specs.water_temp != blank or specs.flow_rate != blank or specs.product_dim_wdh != blank or specs.packing_dim_wdh != blank or specs.net_weight != blank or specs.pallet_qty != blank or specs.container_qty != blank or specs.manual_url != blank or specs.supporting_image != blank
      assign dispenser_5_4_visible = true
    endif
  endif

  assign sparkling_countertop_visible = false
  if family == 'sparkling_countertop' and specs != blank
    if specs.item_no != blank or specs.flow_rate != blank or specs.dimensions_wdh != blank or specs.weight != blank or specs.pallet_qty != blank or specs.manual_url != blank or specs.supporting_image != blank
      assign sparkling_countertop_visible = true
    endif
  endif

  assign sparkling_undersink_visible = false
  if family == 'sparkling_undersink' and specs != blank
    if specs.item_no != blank or specs.flow_rate != blank or specs.tap_tower_dimensions_wdh != blank or specs.system_dimensions != blank or specs.tap_tower_system_weight != blank or specs.pallet_qty != blank or specs.manual_url != blank or specs.supporting_image != blank
      assign sparkling_undersink_visible = true
    endif
  endif

  assign ice_scoop_visible = false
  if family == 'ice_scoop' and specs != blank
    if specs.item_no != blank or specs.dimensions_lwh != blank or specs.ice_output != blank or specs.ice_shape != blank or specs.bin_capacity != blank or specs.compressor != blank or specs.voltage != blank or specs.power != blank or specs.condenser_unit != blank or specs.refrigerant != blank or specs.net_weight != blank or specs.gross_weight != blank or specs.carton_dimensions_lwh != blank or specs.manual_url != blank or specs.supporting_image != blank
      assign ice_scoop_visible = true
    endif
  endif

  assign ice_modular_visible = false
  if family == 'ice_modular' and specs != blank
    if specs.item_no_ice_maker_head != blank or specs.item_no_ice_storage_bin != blank or specs.overall_dimensions_lwh != blank or specs.ice_maker_head_lwh != blank or specs.ice_storage_bin_lwh != blank or specs.ice_output != blank or specs.ice_storage_bin_capacity != blank or specs.ice_shape != blank or specs.compressor != blank or specs.voltage_v_hz != blank or specs.power != blank or specs.condenser_unit != blank or specs.refrigerant != blank or specs.ice_maker_head_net_weight != blank or specs.ice_maker_head_gross_weight != blank or specs.ice_storage_bin_net_weight != blank or specs.ice_storage_bin_gross_weight != blank or specs.ice_maker_head_packing_dim != blank or specs.ice_storage_bin_packing_dim != blank or specs.loading_qty != blank or specs.manual_url != blank or specs.supporting_image != blank
      assign ice_modular_visible = true
    endif
  endif

  assign modular_ice_dispenser_visible = false
  if family == 'modular_ice_dispenser' and specs != blank
    if specs.item_no_ice_maker_head != blank or specs.item_no_ice_dispenser_bin != blank or specs.overall_dimensions_lwh != blank or specs.ice_maker_head_lwh != blank or specs.ice_output != blank or specs.ice_shape != blank or specs.compressor != blank or specs.voltage != blank or specs.power != blank or specs.condenser_unit != blank or specs.refrigerant != blank or specs.ice_maker_weight_net_gross != blank or specs.ice_maker_packing_dimensions != blank or specs.ice_maker_head_loading_qty != blank or specs.ice_maker_whole_lwh != blank or specs.ice_dispenser_bin_lwh != blank or specs.ice_dispenser_bin_capacity != blank or specs.ice_dispenser_bin_power != blank or specs.ice_dispenser_bin_weight_net_gross != blank or specs.ice_dispenser_bin_packing_dimensions != blank or specs.ice_dispenser_bin_loading_qty != blank or specs.manual_url != blank or specs.supporting_image != blank
      assign modular_ice_dispenser_visible = true
    endif
  endif

  assign show_section = false
  if family == 'dispenser_10_6'
    if dispenser_10_6_visible
      assign show_section = true
    endif
  elsif family == 'dispenser_5_4'
    if dispenser_5_4_visible
      assign show_section = true
    endif
  elsif family == 'sparkling_countertop'
    if sparkling_countertop_visible
      assign show_section = true
    endif
  elsif family == 'sparkling_undersink'
    if sparkling_undersink_visible
      assign show_section = true
    endif
  elsif family == 'ice_scoop'
    if ice_scoop_visible
      assign show_section = true
    endif
  elsif family == 'ice_modular'
    if ice_modular_visible
      assign show_section = true
    endif
  elsif family == 'modular_ice_dispenser'
    if modular_ice_dispenser_visible
      assign show_section = true
    endif
  elsif specs != blank
    if has_dimensions or has_features_column or specs.supporting_image != blank
      assign show_section = true
    endif
  endif
-%}

{%- if show_section -%}
  {%- style -%}
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
      padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
    }

    @media screen and (min-width: 750px) {
      .section-{{ section.id }}-padding {
        padding-top: {{ section.settings.padding_top }}px;
        padding-bottom: {{ section.settings.padding_bottom }}px;
      }
    }
  {%- endstyle -%}

  <div
    id="lago-product-specs-{{ section.id }}"
    class="lago-product-specs color-{{ section.settings.color_scheme }} gradient"
  >
    <div class="page-width section-{{ section.id }}-padding">
      {%- assign heading = section.settings.heading -%}
      {%- if specs.display_title != blank -%}
        {%- assign heading = specs.display_title -%}
      {%- endif -%}

      {%- if heading != blank -%}
        <h2 class="lago-product-specs__heading {{ section.settings.heading_size }}">{{ heading | escape }}</h2>
      {%- endif -%}

      {%- if family == 'dispenser_10_6' -%}
        <div
          class="
            lago-product-specs__grid
            {% if specs.supporting_image != blank %}lago-product-specs__grid--split{% endif %}
          "
        >
          <div>
            <dl class="lago-product-specs__dl">
              {%- render 'lago-spec-dl-row', label: 'Model', value: specs.model -%}
              {%- render 'lago-spec-dl-row', label: 'Cleaning System', value: specs.cleaning_system -%}
              {%- render 'lago-spec-dl-row', label: 'Water Temp.', value: specs.water_temp -%}
              {%- render 'lago-spec-dl-row', label: 'Flow Rate', value: specs.flow_rate -%}
              {%- render 'lago-spec-dl-row', label: 'Product Dim (W x D x H)', value: specs.product_dim_wdh -%}
              {%- render 'lago-spec-dl-row', label: 'Hot Tank Volume', value: specs.hot_tank_volume -%}
              {%- render 'lago-spec-dl-row', label: 'Heating Capacity', value: specs.heating_capacity -%}
              {%- render 'lago-spec-dl-row', label: 'Heating Power', value: specs.heating_power -%}
              {%- render 'lago-spec-dl-row', label: 'Cold Tank Volume', value: specs.cold_tank_volume -%}
              {%- render 'lago-spec-dl-row', label: 'Glycol Tank', value: specs.glycol_tank -%}
              {%- render 'lago-spec-dl-row', label: 'Combined Cooling System', value: specs.combined_cooling_system -%}
              {%- render 'lago-spec-dl-row', label: 'Cooling Capacity', value: specs.cooling_capacity -%}
              {%- render 'lago-spec-dl-row', label: 'Cooling Power', value: specs.cooling_power -%}
            </dl>

            {%- if specs.manual_url != blank -%}
