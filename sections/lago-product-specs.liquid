              <div class="lago-product-specs__manual">
                <a
                  href="{{ specs.manual_url }}"
                  class="button button--secondary"
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  {{ section.settings.manual_label | escape }}
                </a>
              </div>
            {%- endif -%}
          </div>

          {%- if specs.supporting_image != blank -%}
            <div class="lago-product-specs__image-wrap">
              <div class="global-media-settings" style="max-width: 900px; width: 100%;">
                {{
                  specs.supporting_image
                  | image_url: width: 900
                  | image_tag:
                    loading: 'lazy',
                    widths: '550, 720, 900',
                    sizes: '(min-width: 990px) 45vw, 100vw',
                    class: 'lago-product-specs__image'
                }}
              </div>
            </div>
          {%- endif -%}
        </div>
      {%- elsif family == 'modular_ice_dispenser' -%}
        <div
          class="
            lago-product-specs__grid
            {% if specs.supporting_image != blank %}lago-product-specs__grid--split{% endif %}
          "
        >
          <div>
            <dl class="lago-product-specs__dl">
              {%- render 'lago-spec-dl-row', label: 'Item No. - Ice Maker Head', value: specs.item_no_ice_maker_head -%}
              {%- render 'lago-spec-dl-row', label: 'Item No. - Ice Dispenser Bin', value: specs.item_no_ice_dispenser_bin -%}
              {%- render 'lago-spec-dl-row', label: 'Overall Dimensions (L x W x H)', value: specs.overall_dimensions_lwh -%}
              {%- render 'lago-spec-dl-row', label: 'Ice Maker Head (L x W x H)', value: specs.ice_maker_head_lwh -%}
              {%- render 'lago-spec-dl-row', label: 'Ice Output', value: specs.ice_output -%}
              {%- render 'lago-spec-dl-row', label: 'Ice Shape', value: specs.ice_shape -%}
              {%- render 'lago-spec-dl-row', label: 'Compressor', value: specs.compressor -%}
              {%- render 'lago-spec-dl-row', label: 'Voltage (V/Hz)', value: specs.voltage -%}
              {%- render 'lago-spec-dl-row', label: 'Power', value: specs.power -%}
              {%- render 'lago-spec-dl-row', label: 'Condenser Unit', value: specs.condenser_unit -%}
              {%- render 'lago-spec-dl-row', label: 'Refrigerant', value: specs.refrigerant -%}
              {%- render 'lago-spec-dl-row', label: 'Ice Maker Weight, Net / Gross', value: specs.ice_maker_weight_net_gross -%}
              {%- render 'lago-spec-dl-row', label: 'Ice Maker Packing Dimensions', value: specs.ice_maker_packing_dimensions -%}
              {%- render 'lago-spec-dl-row', label: 'Ice Maker Head Loading Qty. (20GP/40HQ)', value: specs.ice_maker_head_loading_qty -%}
              {%- render 'lago-spec-dl-row', label: 'Ice Maker Whole Set Load. Qty (20GP/40HQ)', value: specs.ice_maker_whole_lwh -%}
              {%- render 'lago-spec-dl-row', label: 'Ice Dispenser Bin (L x W x H)', value: specs.ice_dispenser_bin_lwh -%}
              {%- render 'lago-spec-dl-row', label: 'Ice Dispenser Bin Capacity', value: specs.ice_dispenser_bin_capacity -%}
              {%- render 'lago-spec-dl-row', label: 'Ice Dispenser Bin Power', value: specs.ice_dispenser_bin_power -%}
              {%- render 'lago-spec-dl-row', label: 'Ice Dispenser Bin Weight, Net/Gross', value: specs.ice_dispenser_bin_weight_net_gross -%}
              {%- render 'lago-spec-dl-row', label: 'Ice Dispenser Bin Packing Dimensions', value: specs.ice_dispenser_bin_packing_dimensions -%}
              {%- render 'lago-spec-dl-row', label: 'Ice Dispenser Bin Loading Qty (20GP/40HQ)', value: specs.ice_dispenser_bin_loading_qty -%}
            </dl>

            {%- if specs.manual_url != blank -%}
              <div class="lago-product-specs__manual">
                <a
                  href="{{ specs.manual_url }}"
                  class="button button--secondary"
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  {{ section.settings.manual_label | escape }}
                </a>
              </div>
            {%- endif -%}
          </div>

          {%- if specs.supporting_image != blank -%}
            <div class="lago-product-specs__image-wrap">
              <div class="global-media-settings" style="max-width: 900px; width: 100%;">
                {{
                  specs.supporting_image
                  | image_url: width: 900
                  | image_tag:
                    loading: 'lazy',
                    widths: '550, 720, 900',
                    sizes: '(min-width: 990px) 45vw, 100vw',
                    class: 'lago-product-specs__image'
                }}
              </div>
            </div>
          {%- endif -%}
        </div>
      {%- else -%}
        <div
          class="
            lago-product-specs__grid
            {% if specs.supporting_image != blank %}lago-product-specs__grid--split{% endif %}
          "
        >
          <div>
            <div
              class="
                lago-product-specs__columns
                {% if specs.supporting_image == blank and has_dimensions and has_features_column %}lago-product-specs__columns--two{% endif %}
              "
            >
              {%- if has_dimensions -%}
                <div>
                  <h3 class="lago-product-specs__group-title">{{ section.settings.dimensions_heading | escape }}</h3>
                  <dl class="lago-product-specs__dl">
                    {%- assign property_list = specs.dimensions | split: '|' -%}
                    {%- for property in property_list -%}
                      {%- assign property_tuple = property | split: ':' -%}
                      {%- if property_tuple.first != blank -%}
                        <div class="lago-product-specs__row">
                          <dt>{{ property_tuple.first | strip | escape }}</dt>
                          <dd>{{ property_tuple.last | strip | escape }}</dd>
                        </div>
                      {%- endif -%}
                    {%- endfor -%}
                  </dl>
                </div>
              {%- endif -%}

              {%- if has_features_column -%}
                <div>
                  <h3 class="lago-product-specs__group-title">{{ section.settings.features_heading | escape }}</h3>
                  <dl class="lago-product-specs__dl">
                    {%- if spec_rows_count > 0 -%}
                      {%- for row in specs.spec_rows.value -%}
                        {%- if row.label != blank -%}
                          <div class="lago-product-specs__row">
                            <dt>{{ row.label | escape }}</dt>
                            <dd>{{ row.value | escape }}</dd>
                          </div>
                        {%- endif -%}
                      {%- endfor -%}
                    {%- endif -%}

                    {%- if has_additional -%}
                      {%- assign add_list = specs.additional_specs | split: '|' -%}
                      {%- for property in add_list -%}
                        {%- assign property_tuple = property | split: ':' -%}
                        {%- if property_tuple.first != blank -%}
                          <div class="lago-product-specs__row">
                            <dt>{{ property_tuple.first | strip | escape }}</dt>
                            <dd>{{ property_tuple.last | strip | escape }}</dd>
                          </div>
                        {%- endif -%}
                      {%- endfor -%}
                    {%- endif -%}

                    {%- if has_materials -%}
                      <div class="lago-product-specs__row">
                        <dt>{{ section.settings.materials_label | escape }}</dt>
                        <dd>{{ specs.materials | escape }}</dd>
                      </div>
                    {%- endif -%}
                  </dl>

                  {%- if has_manual -%}
                    <div class="lago-product-specs__manual">
                      <a
                        href="{{ specs.manual_url }}"
                        class="button button--secondary"
                        target="_blank"
                        rel="noopener noreferrer"
                      >
                        {{ section.settings.manual_label | escape }}
                      </a>
                    </div>
                  {%- endif -%}
                </div>
              {%- endif -%}
            </div>
          </div>

          {%- if specs.supporting_image != blank -%}
            <div class="lago-product-specs__image-wrap">
              <div class="global-media-settings" style="max-width: 900px; width: 100%;">
                {{
                  specs.supporting_image
                  | image_url: width: 900
                  | image_tag:
                    loading: 'lazy',
                    widths: '550, 720, 900',
                    sizes: '(min-width: 990px) 45vw, 100vw',
                    class: 'lago-product-specs__image'
                }}
              </div>
            </div>
          {%- endif -%}
        </div>
      {%- endif -%}
    </div>
  </div>
{%- endif -%}

{% schema %}
{
  "name": "Product specs",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "select",
      "id": "product_family",
      "label": "Specification profile",
      "options": [
        { "value": "dispenser_10_6", "label": "10-6 water dispensers" },
        { "value": "dispenser_5_4", "label": "5-4 water dispensers" },
        { "value": "sparkling_countertop", "label": "Sparkling countertop dispensers" },
        { "value": "sparkling_undersink", "label": "Sparkling undersink dispensers" },
        { "value": "ice_scoop", "label": "Scoop ice machines" },
        { "value": "ice_modular", "label": "Modular ice machines" },
        { "value": "modular_ice_dispenser", "label": "Modular ice dispenser" }
      ],
      "default": "dispenser_10_6"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Specifications"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading size",
      "options": [
        { "value": "h2", "label": "Small" },
        { "value": "h1", "label": "Medium" },
        { "value": "h0", "label": "Large" }
      ],
      "default": "h1"
    },
    {
      "type": "text",
      "id": "dimensions_heading",
      "label": "Dimensions column title",
      "default": "Dimensions"
    },
    {
      "type": "text",
      "id": "features_heading",
      "label": "Features column title",
      "default": "Features"
    },
    {
      "type": "text",
      "id": "materials_label",
      "label": "Materials row label",
      "default": "Materials"
    },
    {
      "type": "text",
      "id": "manual_label",
      "label": "Manual button label",
      "default": "Instruction manual"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 36
    }
  ],
  "presets": [
    {
      "name": "Product specs"
    }
  ]
}
{% endschema %}
