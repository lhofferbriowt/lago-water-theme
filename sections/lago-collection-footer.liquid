{{ 'section-lago-home-1-5.css' | asset_url | stylesheet_tag }}

<div class="lago-home-1-5">
  {% render 'lago-home-1-5-footer' %}
</div>

{% schema %}
{
  "name": "Lago 1.5 collection footer",
  "tag": "section",
  "class": "section section-lago-collection-footer",
  "enabled_on": {
    "templates": ["collection"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Footer band"
    },
    {
      "type": "image_picker",
      "id": "footer_logo",
      "label": "Logo"
    },
    {
      "type": "textarea",
      "id": "footer_intro",
      "label": "Intro text",
      "default": "At Lago we understand our dealers and their customers which enables us to provide the best filtration products to fit your needs. Our goal is that with every sip you take you feel the passion we put into all of our products."
    },
    {
      "type": "text",
      "id": "footer_resources_heading",
      "label": "Resources column heading",
      "default": "Resources"
    },
    {
      "type": "text",
      "id": "label_home",
      "label": "Nav — Home label",
      "default": "Home"
    },
    {
      "type": "url",
      "id": "link_home",
      "label": "Nav — Home link"
    },
    {
      "type": "text",
      "id": "label_dispensers",
      "label": "Nav — Water dispensers label",
      "default": "Water Dispensers"
    },
    {
      "type": "url",
      "id": "link_dispensers",
      "label": "Nav — Water dispensers link"
    },
    {
      "type": "text",
      "id": "label_filtration",
      "label": "Nav — Filtration label",
      "default": "Filtration Systems"
    },
    {
      "type": "text",
      "id": "label_why_lago",
      "label": "Nav — Why Lago label",
      "default": "Why Lago"
    },
    {
      "type": "url",
      "id": "link_why_lago",
      "label": "Nav — Why Lago link"
    },
    {
      "type": "url",
      "id": "link_filtration",
      "label": "Nav — Filtration link"
    },
    {
      "type": "text",
      "id": "label_dealer",
      "label": "Nav — Become a dealer label",
      "default": "Become a Dealer"
    },
    {
      "type": "url",
      "id": "link_dealer",
      "label": "Nav — Become a dealer link"
    },
    {
      "type": "text",
      "id": "footer_contact_heading",
      "label": "Contact column heading",
      "default": "Contact Us"
    },
    {
      "type": "text",
      "id": "footer_phone",
      "label": "Phone (display)",
      "default": "(800) 555-0123"
    },
    {
      "type": "text",
      "id": "footer_email",
      "label": "Email",
      "default": "info@lagowater.com"
    },
    {
      "type": "textarea",
      "id": "footer_copyright",
      "label": "Copyright line",
      "default": "©2025 Brio Water Technology. Inc. All rights reserved. Lago is a registered trademark of Brio Water Tech., INC."
    }
  ],
  "presets": [
    {
      "name": "Lago 1.5 collection footer"
    }
  ]
}
{% endschema %}
