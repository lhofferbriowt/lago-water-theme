{{ 'section-lago-home-1-5.css' | asset_url | stylesheet_tag }}

<div class="lago-home-1-5">
  <div class="lago-home-1-5__inner">
    <section class="l15-hero" aria-labelledby="l15-hero-heading">
      <div class="l15-hero__wrap">
        <div class="l15-hero__media">
          {%- if section.settings.hero_image != blank or section.settings.hero_bg_desktop != blank -%}
            <picture>
              {%- if section.settings.hero_bg_desktop != blank -%}
                <source
                  media="(min-width: 990px)"
                  srcset="{{ section.settings.hero_bg_desktop | image_url: width: 1100 }} 1100w, {{ section.settings.hero_bg_desktop | image_url: width: 1440 }} 1440w, {{ section.settings.hero_bg_desktop | image_url: width: 1920 }} 1920w, {{ section.settings.hero_bg_desktop | image_url: width: 2400 }} 2400w, {{ section.settings.hero_bg_desktop | image_url: width: 2880 }} 2880w"
                >
              {%- endif -%}

              {%- if section.settings.hero_image != blank -%}
                {%- assign l15_hero_alt = section.settings.hero_image.alt | default: shop.name -%}
                {{
                  section.settings.hero_image
                  | image_url: width: 1600
                  | image_tag:
                    loading: 'eager',
                    class: 'l15-hero__photo',
                    sizes: '(max-width: 989px) 100vw, 1440px',
                    widths: '375, 550, 750, 900, 1100, 1280, 1440, 1600, 1920, 2400',
                    alt: l15_hero_alt
                }}
              {%- elsif section.settings.hero_bg_desktop != blank -%}
                {%- assign l15_hero_alt = section.settings.hero_bg_desktop.alt | default: shop.name -%}
                {{
                  section.settings.hero_bg_desktop
                  | image_url: width: 2000
                  | image_tag:
                    loading: 'eager',
                    class: 'l15-hero__photo',
                    sizes: '(max-width: 989px) 100vw, 1440px',
                    widths: '750, 900, 1100, 1280, 1440, 1600, 1920, 2400',
                    alt: l15_hero_alt
                }}
              {%- endif -%}
            </picture>
          {%- else -%}
            <div class="l15-hero__placeholder" aria-hidden="true"></div>
          {%- endif -%}
        </div>

        <div class="l15-hero__content">
          <div
            class="l15-hero__heading-wrap"
            style="
              --l15-hero-heading-mt: {{ section.settings.hero_heading_margin_top }}px;
              --l15-hero-heading-mb: {{ section.settings.hero_heading_margin_bottom }}px;
              --l15-hero-button-mt: {{ section.settings.hero_button_margin_top }}px;
              --l15-hero-button-mb: {{ section.settings.hero_button_margin_bottom }}px;
              --l15-hero-heading-font-size-mobile: {{ section.settings.hero_heading_font_size_mobile }}px;
              --l15-hero-heading-font-size-desktop: {{ section.settings.hero_heading_font_size_desktop }}px;
            "
          >
            <h1 id="l15-hero-heading" class="l15-hero__text">{{ section.settings.hero_heading | escape }}</h1>
            {%- if section.settings.hero_button_label != blank -%}
              <a class="l15-btn" href="{{ section.settings.hero_button_link | default: '#' }}">
                {{ section.settings.hero_button_label | escape }}
              </a>
            {%- endif -%}
          </div>
        </div>
      </div>
    </section>
  </div>
</div>

{% schema %}
{
  "name": "Lago home — Hero",
  "tag": "section",
  "class": "section section-lago-home-hero",
  "settings": [
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero background — mobile"
    },
    {
      "type": "image_picker",
      "id": "hero_bg_desktop",
      "label": "Hero background — desktop",
      "info": "Shown from 990px up. If empty, the mobile background is used at all breakpoints."
    },
    {
      "type": "textarea",
      "id": "hero_heading",
      "label": "Hero heading",
      "default": "Your water solution partner for residential and commercial settings."
    },
    {
      "type": "range",
      "id": "hero_heading_font_size_desktop",
      "min": 18,
      "max": 90,
      "step": 2,
      "unit": "px",
      "label": "Hero heading font size (desktop)",
      "default": 48
    },
    {
      "type": "range",
      "id": "hero_heading_font_size_mobile",
      "min": 14,
      "max": 48,
      "step": 1,
      "unit": "px",
      "label": "Hero heading font size (mobile)",
      "default": 24
    },
    {
      "type": "header",
      "content": "Hero spacing"
    },
    {
      "type": "range",
      "id": "hero_heading_margin_top",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "label": "Hero heading margin top",
      "default": 0
    },
    {
      "type": "range",
      "id": "hero_heading_margin_bottom",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "label": "Hero heading margin bottom",
      "default": 20
    },
    {
      "type": "text",
      "id": "hero_button_label",
      "label": "Hero button label",
      "default": "Become a Dealer"
    },
    {
      "type": "url",
      "id": "hero_button_link",
      "label": "Hero button link"
    },
    {
      "type": "range",
      "id": "hero_button_margin_top",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "label": "Hero button margin top",
      "default": 20
    },
    {
      "type": "range",
      "id": "hero_button_margin_bottom",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "label": "Hero button margin bottom",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Lago home — Hero"
    }
  ]
}
{% endschema %}
