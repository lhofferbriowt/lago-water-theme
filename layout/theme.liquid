<script src="https://code.jquery.com/jquery-3.7.1.min.js" defer></script>
<script src="https://cdn.jsdelivr.net/npm/gsap@3.12.5/dist/gsap.min.js" defer></script>
<script src="https://cdn.jsdelivr.net/npm/gsap@3.12.5/dist/ScrollTrigger.min.js" defer></script>

<script>
  //alert('pws');
  window.addEventListener('DOMContentLoaded', function () {
    if (!window.gsap || !window.ScrollTrigger) return;
    gsap.registerPlugin(ScrollTrigger);

    // --- KNOBS ---
    const GROUPS          = 4;          // reveal the text in 4 scroll phases
    const PX_PER_GROUP    = 500;        // scroll distance per group (raise = slower)
    const STAGGER_IN_GROUP= 0.12;       // slight stagger inside each group
    const SCRUB_SMOOTH    = 0.6;        // 0 = hard tie to scroll, higher = smoother easing
    const START_OFFSET    = "top top";
    const ANTICIPATE      = 1;

    // If you still have <br><br> in content and can't edit HTML, uncomment to remove them visually:
    // document.querySelectorAll('.tt-text-reveal br').forEach(br => br.style.display = 'none');

    // Wrap each paragraph's text in a span we can paint
    document.querySelectorAll('.tt-text-reveal').forEach(block => {
      if (block.dataset.wrapped) return;

      // Find paragraphs; if none exist (e.g. old HTML), synthesize from <br><br>.
      let paras = Array.from(block.querySelectorAll('p'));
      if (!paras.length) {
        const parts = block.innerHTML.split(/<br\s*\/?>\s*<br\s*\/?>/gi).map(s => s.trim()).filter(Boolean);
        block.innerHTML = '';
        parts.forEach(txt => {
          const p = document.createElement('p');
          p.innerHTML = txt;
          block.appendChild(p);
        });
        paras = Array.from(block.querySelectorAll('p'));
      }

      // Wrap each paragraph’s inline content with a paintable span
      paras.forEach(p => {
        // Keep existing inline HTML (links/emphasis) intact
        const wrapper = document.createElement('span');
        wrapper.className = 'tt-reveal-span';
        wrapper.innerHTML = p.innerHTML;
        p.innerHTML = '';
        p.appendChild(wrapper);
      });

      block.dataset.wrapped = 'true';
    });

    // For each reveal block, create its scroll timeline
    document.querySelectorAll(".tt-text-reveal").forEach(ttTextReveal => {
      const spans = ttTextReveal.querySelectorAll(".tt-reveal-span");
      if (!spans.length) return;

      // Initial state
      gsap.set(spans, { backgroundSize: "0% 100%" });

      // Pin the outer section for the whole sequence
      const parentSection = ttTextReveal.closest(".cst_text_animation") || ttTextReveal;

      const groups = GROUPS;
      const spansPerGroup = Math.ceil(spans.length / groups);
      const endDistance = groups * PX_PER_GROUP;

      const tl = gsap.timeline({
        defaults: { ease: "power1.out" },
        scrollTrigger: {
          trigger: parentSection,
          start: START_OFFSET,
          end: "+=" + endDistance,
          scrub: SCRUB_SMOOTH,
          pin: true,
          anticipatePin: ANTICIPATE,
          markers: false
        }
      });

      // Build 4 phases; each phase animates its chunk of paragraphs
      for (let g = 0; g < groups; g++) {
        const startIdx = g * spansPerGroup;
        const endIdx   = Math.min(startIdx + spansPerGroup, spans.length);
        const chunk    = Array.from(spans).slice(startIdx, endIdx);
        if (!chunk.length) continue;

        tl.to(chunk, {
          backgroundSize: "100% 100%",
          stagger: STAGGER_IN_GROUP
        }, "+=0"); // timeline step per group
      }
    });
  });
</script>




